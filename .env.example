# WSJ Digest — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is loaded automatically by run_digest.py via python-dotenv.
# NEVER commit your real .env file to git.

# ------------------------------------------------------------------ #
# WSJ Account Credentials                                             #
# Required for authenticated section scraping.                       #
# RSS feeds (the primary data source) work without authentication.   #
# ------------------------------------------------------------------ #
WSJ_EMAIL=your-email@example.com
WSJ_PASSWORD=your-wsj-password-here

# ------------------------------------------------------------------ #
# Optional settings (override config/categories.yaml values)         #
# ------------------------------------------------------------------ #

# Enable Playwright browser automation (requires extra install steps)
# See SETUP.md for installation instructions.
# USE_PLAYWRIGHT=0

# Override log verbosity: DEBUG | INFO | WARNING | ERROR
# WSJ_LOG_LEVEL=INFO

# Override article age cutoff (hours)
# WSJ_MAX_AGE_HOURS=48
